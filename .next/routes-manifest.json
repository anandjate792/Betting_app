      "page": "/api/prediction-slots/[slotId]",
      "regex": "^/api/prediction\\-slots/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslotId": "nxtPslotId"
      },
      "namedRegex": "^/api/prediction\\-slots/(?<nxtPslotId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/transactions/[transactionId]",
